{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "types": ["node", "react", "react-dom"],
    "incremental": true
  },
  "include": ["next-env.d.ts", "app", "src", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
