NODE_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info
REQUEST_ID_HEADER=x-request-id
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
TRACING_ENABLED=false
OTEL_SERVICE_NAME=attendease-api
OTEL_EXPORTER_OTLP_ENDPOINT=
API_PORT=4000
DATABASE_URL=postgresql://attendease:attendease@localhost:5432/attendease
REDIS_URL=redis://localhost:6379
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE_MODE=memory
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
ATTENDANCE_MARK_RATE_LIMIT_MAX=6
ATTENDANCE_MARK_RATE_LIMIT_WINDOW_SECONDS=60
FEATURE_BLUETOOTH_ATTENDANCE_ENABLED=true
FEATURE_EMAIL_AUTOMATION_ENABLED=true
FEATURE_STRICT_DEVICE_BINDING_MODE=ENFORCE
ROSTER_IMPORT_BATCH_SIZE=10
ANNOUNCEMENT_FANOUT_BATCH_SIZE=20
ANALYTICS_REFRESH_BATCH_SIZE=20
EXPORT_JOB_BATCH_SIZE=10
EMAIL_AUTOMATION_SCHEDULE_BATCH_SIZE=100
EMAIL_AUTOMATION_PROCESS_BATCH_SIZE=10
ROSTER_IMPORT_STUCK_TIMEOUT_MS=900000
OUTBOX_STUCK_TIMEOUT_MS=900000
EXPORT_JOB_STUCK_TIMEOUT_MS=900000
QUEUE_HEALTH_STALE_AFTER_MS=900000
EMAIL_AUTOMATION_STUCK_DISPATCH_TIMEOUT_MS=900000
AUTH_ISSUER=attendease-api
AUTH_AUDIENCE=attendease-clients
AUTH_ACCESS_TOKEN_SECRET=attendease-dev-access-token-secret-attendease
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
GOOGLE_OIDC_CLIENT_ID=attendease-google-client-id
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=http://localhost:4000/auth/google/callback
GOOGLE_TEACHER_ALLOWED_DOMAINS=attendease.dev
GOOGLE_STUDENT_ALLOWED_DOMAINS=attendease.dev
ATTENDANCE_QR_ALLOWED_CLOCK_SKEW_SLICES=1
ATTENDANCE_BLUETOOTH_ALLOWED_CLOCK_SKEW_SLICES=1
ATTENDANCE_BLUETOOTH_PROTOCOL_VERSION=1
ATTENDANCE_BLUETOOTH_SERVICE_UUID=12345678-1234-5678-1234-56789abc0001
ATTENDANCE_GPS_MAX_ACCURACY_METERS=100
DEVICE_ATTESTATION_ANDROID_MODE=placeholder
DEVICE_ATTESTATION_APPLE_MODE=placeholder
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=attendease-local
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900
EXPORT_FILE_TTL_HOURS=72
