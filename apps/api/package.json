{
  "name": "@attendease/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "tsx dist/apps/api/src/main.js",
    "lint": "biome check src package.json tsconfig.json tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/**/*.integration.test.ts"
  },
  "dependencies": {
    "@attendease/auth": "workspace:^",
    "@attendease/config": "workspace:*",
    "@attendease/contracts": "workspace:*",
    "@attendease/db": "workspace:^",
    "@attendease/domain": "workspace:^",
    "@attendease/email": "workspace:^",
    "@attendease/export": "workspace:^",
    "@attendease/utils": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@sentry/node": "^10.21.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-fastify": "^11.1.16",
    "google-auth-library": "^10.6.1",
    "ioredis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.16",
    "@types/pg": "^8.15.5",
    "pg": "^8.16.3"
  }
