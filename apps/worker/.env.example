NODE_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info
REQUEST_ID_HEADER=x-request-id
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
TRACING_ENABLED=false
OTEL_SERVICE_NAME=attendease-worker
OTEL_EXPORTER_OTLP_ENDPOINT=
WORKER_PORT=4010
DATABASE_URL=postgresql://attendease:attendease@localhost:5432/attendease
REDIS_URL=redis://localhost:6379
WORKER_CYCLE_INTERVAL_MS=5000
FEATURE_BLUETOOTH_ATTENDANCE_ENABLED=true
FEATURE_EMAIL_AUTOMATION_ENABLED=true
FEATURE_STRICT_DEVICE_BINDING_MODE=ENFORCE
ROSTER_IMPORT_BATCH_SIZE=10
ANNOUNCEMENT_FANOUT_BATCH_SIZE=20
ANALYTICS_REFRESH_BATCH_SIZE=20
EXPORT_JOB_BATCH_SIZE=10
EMAIL_AUTOMATION_SCHEDULE_BATCH_SIZE=100
EMAIL_AUTOMATION_PROCESS_BATCH_SIZE=10
ROSTER_IMPORT_STUCK_TIMEOUT_MS=900000
OUTBOX_STUCK_TIMEOUT_MS=900000
EXPORT_JOB_STUCK_TIMEOUT_MS=900000
QUEUE_HEALTH_STALE_AFTER_MS=900000
EMAIL_AUTOMATION_STUCK_DISPATCH_TIMEOUT_MS=900000
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=attendease-local
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900
EXPORT_FILE_TTL_HOURS=72
EMAIL_PROVIDER_MODE=console
EMAIL_FROM_ADDRESS=noreply@attendease.local
EMAIL_REPLY_TO_ADDRESS=teacher@attendease.local
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=attendease-ses-access-key
AWS_SES_SECRET_ACCESS_KEY=attendease-ses-secret-key
AWS_SES_ENDPOINT=
AWS_SES_CONFIGURATION_SET=
