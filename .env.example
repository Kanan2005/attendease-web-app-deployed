NODE_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info
REQUEST_ID_HEADER=x-request-id
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
TRACING_ENABLED=false
OTEL_SERVICE_NAME=attendease-api
OTEL_EXPORTER_OTLP_ENDPOINT=
